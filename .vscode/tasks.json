{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Dev - Start Development",
      "type": "shell",
      "command": "cmd.exe",
      "args": ["/c", "npm", "--prefix", "frontend", "run", "dev"],
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Local:.*",
          "endsPattern": "^.*Network:.*"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
